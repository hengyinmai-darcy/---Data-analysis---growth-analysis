   "source": [
    "query_growth = \"\"\"\n",
    "\n",
    "WITH yearly_content AS (\n",
    "\n",
    "    SELECT\n",
    "\n",
    "        year_added,\n",
    "        COUNT(show_id) AS total_content\n",
    "\n",
    "    FROM netflix\n",
    "\n",
    "    GROUP BY year_added\n",
    ")\n",
    "\n",
    "SELECT\n",
    "\n",
    "    year_added,\n",
    "\n",
    "    total_content,\n",
    "\n",
    "    LAG(total_content) OVER (\n",
    "        ORDER BY year_added\n",
    "    ) AS previous_year,\n",
    "\n",
    "    ROUND(\n",
    "\n",
    "        (\n",
    "            total_content -\n",
    "            LAG(total_content) OVER (\n",
    "                ORDER BY year_added\n",
    "            )\n",
    "        )\n",
    "\n",
    "        * 100.0\n",
    "\n",
    "        /\n",
    "\n",
    "        LAG(total_content) OVER (\n",
    "            ORDER BY year_added\n",
    "        ),\n",
    "\n",
    "        2\n",
    "\n",
    "    ) AS growth_rate\n",
    "\n",
    "FROM yearly_content\n",
    "\n",
    "\"\"\"\n",
    "growth_rate_df = pd.read_sql(\n",
    "    query_growth,\n",
    "    conn\n",
    ")\n",
    "growth_rate_df"
   ]
